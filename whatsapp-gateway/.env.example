# URL del webhook Flask del CMMS
#   Desarrollo local:  http://localhost:5000/api/public/whatsapp/webhook
#   Produccion:        https://TU-APP.onrender.com/api/public/whatsapp/webhook
WEBHOOK_URL=http://localhost:5000/api/public/whatsapp/webhook

# Token compartido gateway <-> Flask. Debe coincidir con WHATSAPP_GATEWAY_TOKEN
# en el .env del CMMS. Genera uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
GATEWAY_TOKEN=

# (Opcional) Numero del dueño SIN + ni espacios (ej: 51987654321).
# Unico autorizado para el comando /grupos (lista JIDs de grupos).
OWNER_NUMBER=

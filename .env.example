DB_MODE=supabase
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
LOCAL_DATABASE_URL=sqlite:///cmms_v2.db
SUPABASE_PROBE_TIMEOUT_SEC=3
ALLOW_LOCAL_FALLBACK=0

# Bot de Telegram
TELEGRAM_TOKEN=
DEEPSEEK_API_KEY=
# Opcional: habilita transcripcion de mensajes de voz (Whisper API).
# Sin esta clave, el bot responde indicando que la funcion no esta configurada.
OPENAI_API_KEY=
# Autorizacion del bot: chat_id del propietario (admin) y lista de chat_ids
# permitidos (separados por coma). Si ambos estan vacios, el bot rechaza
# todos los mensajes. El OWNER siempre queda autorizado aunque no aparezca
# en la lista.
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# Flask
# - SECRET_KEY: clave aleatoria de >=32 caracteres. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# - FLASK_ENV: 'production' (default) o 'development'. En produccion se
#   exige SECRET_KEY fuerte; el arranque falla en caso contrario.
SECRET_KEY=
FLASK_ENV=production

DB_MODE=supabase
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
LOCAL_DATABASE_URL=sqlite:///cmms_v2.db
SUPABASE_PROBE_TIMEOUT_SEC=3
ALLOW_LOCAL_FALLBACK=0

# Bot de Telegram
TELEGRAM_TOKEN=
DEEPSEEK_API_KEY=
# Opcional: habilita transcripcion de mensajes de voz (Whisper API).
# Sin esta clave, el bot responde indicando que la funcion no esta configurada.
OPENAI_API_KEY=

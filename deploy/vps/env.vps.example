# Plantilla del .env del VPS. Copiar como deploy/vps/.env EN EL VPS y completar.
# ¡NUNCA subir el .env real al repo (es publico)!

# ── Base de datos: el VPS usa su PostgreSQL local (contenedor cmms-db) ──
DB_MODE=local
LOCAL_DATABASE_URL=postgresql://cmms:CAMBIAR_PASSWORD@db:5432/cmms

# Password del PostgreSQL local (la usa docker-compose para crear el contenedor;
# debe coincidir con la de LOCAL_DATABASE_URL)
CMMS_DB_PASSWORD=CAMBIAR_PASSWORD

# Carpeta del host donde se guardan dumps de sincronizacion (montada en /backups)
CMMS_BACKUPS_DIR=/home/bryam16/cmms/backups

# ── Sincronizacion manual: origen Supabase ──
# OJO: puerto 5432 (session mode del pooler), NO 6543 (transaction mode no
# soporta pg_dump).
SUPABASE_DB_URL=postgresql://postgres.PROYECTO:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require

# ── Supabase Storage (las fotos siguen viviendo en Supabase) ──
SUPABASE_URL=https://PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=CAMBIAR

# ── Flask ──
SECRET_KEY=CAMBIAR_64_CHARS
FLASK_ENV=production
LOG_LEVEL=INFO

# ── IA ──
DEEPSEEK_API_KEY=CAMBIAR
OPENAI_API_KEY=CAMBIAR

# ── Bot WhatsApp (por si el gateway hace failover hacia el VPS) ──
WHATSAPP_GATEWAY_TOKEN=CAMBIAR
WHATSAPP_DRY_RUN=0

# ── IMPORTANTE: NO definir TELEGRAM_TOKEN aqui ──
# El bot de Telegram debe correr SOLO en Render (primario). Si se define aqui,
# habria dos bots haciendo polling y los mensajes se duplicarian/perderian.

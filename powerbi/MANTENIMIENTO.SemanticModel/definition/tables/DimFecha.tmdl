		sourceColumn: [Es Fin Semana]

	partition DimFecha-374c11d2b2684fe0 = calculated
		mode: import
		source =
				ADDCOLUMNS(
				    CALENDAR(DATE(2024,1,1), DATE(2030,12,31)),
				    "Año", YEAR([Date]),
				    "Mes", MONTH([Date]),
				    "Nombre Mes", FORMAT([Date], "MMMM"),
				    "Mes Corto", FORMAT([Date], "MMM"),
				    "Año-Mes", FORMAT([Date], "YYYY-MM"),
				    "Trimestre", "Q" & FORMAT([Date], "Q"),
				    "Año-Trimestre", FORMAT([Date], "YYYY") & "-Q" & FORMAT([Date], "Q"),
				    "Día", DAY([Date]),
				    "Día Semana", WEEKDAY([Date],2),
				    "Nombre Día", FORMAT([Date], "DDDD"),
				    "Semana ISO", WEEKNUM([Date],21),
				    "Año-Semana", FORMAT([Date],"YYYY") & "-S" & FORMAT(WEEKNUM([Date],21),"00"),
				    "Es Fin Semana", IF(WEEKDAY([Date],2)>5, TRUE(), FALSE())
				)

	annotation PBI_ResultType = {"type":"table"}

